# ===== Python =====
__pycache__/
*.py[cod]
*.egg-info/
.pytest_cache/

# ===== 数据语料（受版权保护，不入库）=====
# PDF 原文与派生 md/图：体积大且含版权，不推送到远程
data/raw/*
data/paper_raw/*
data/papers/*
data/llm_work/*
data/tmp/**
data/logs/**
data/jobs/**
data/transactions/**
data/jobs/upload_staging/**
data/discovery/doi_candidates/**
data/discovery/pdf_fetch_logs/**
data/discovery/fetch_logs/**
data/cleanup_report.json
data/locks/*.lock
import/
_test_batch/
!data/raw/.gitkeep
!data/paper_raw/.gitkeep
!data/papers/.gitkeep
!data/llm_work/.gitkeep
!data/tmp/.gitkeep
!data/logs/.gitkeep
!data/jobs/.gitkeep
!data/transactions/.gitkeep
!data/discovery/.gitkeep
!data/discovery/doi_candidates/.gitkeep
!data/discovery/pdf_fetch_logs/.gitkeep

# ===== 写作任务产物（可重新生成，不入库）=====
write/jobs/**
!write/.gitkeep
!write/README.md
!write/jobs/
!write/jobs/.gitkeep

# ===== 日志与临时 =====
*.log
output/
.DS_Store
Thumbs.db

