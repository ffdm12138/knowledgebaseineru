# 换行符收敛：文本文件统一以 LF 入库，消除 autocrlf 的 CRLF warning。
# Windows 检出时本地工作区仍可由 git 按需转换（core.autocrlf），不影响编辑。

# 默认：所有文本文件 LF
* text=auto eol=lf

# 显式声明主要文本类型（确保跨平台一致）
*.py     text eol=lf
*.md     text eol=lf
*.json   text eol=lf
*.html   text eol=lf
*.css    text eol=lf
*.js     text eol=lf
*.yml    text eol=lf
*.yaml   text eol=lf
*.toml   text eol=lf
*.txt    text eol=lf
*.bat    text eol=lf
*.sh     text eol=lf
*.bib    text eol=lf
*.tex    text eol=lf
*.cfg    text eol=lf
*.ini    text eol=lf

# 二进制：不做换行符转换
*.png    binary
*.jpg    binary
*.jpeg   binary
*.gif    binary
*.bmp    binary
*.webp   binary
*.pdf    binary
*.zip    binary
*.docx   binary
*.pptx   binary
*.xlsx   binary
