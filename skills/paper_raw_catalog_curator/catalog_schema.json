{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "paper_raw catalog v1.1",
  "description": "Catalog generated by the paper_raw_catalog_curator skill. Mirrors src/services/v2_library.py::empty_catalog().",
  "type": "object",
  "required": [
    "schema_version",
    "display",
    "classification",
    "research_card",
    "evidence_profile",
    "screening",
    "reading_priority",
    "technical_tags",
    "llm_search_text"
  ],
  "properties": {
    "schema_version": { "const": "1.1" },
    "display": {
      "type": "object",
      "required": ["title_original", "title_zh", "short_name_zh", "year", "first_author", "authors_short", "venue", "doi"],
      "properties": {
        "title_original": { "type": "string" },
        "title_zh": { "type": "string" },
        "short_name_zh": { "type": "string", "description": "8-24 汉字，用于文件夹命名" },
        "year": { "type": ["integer", "string", "null"] },
        "first_author": { "type": "string" },
        "authors_short": { "type": "string", "description": "如 Shao et al. 或 Déry and Yau" },
        "venue": { "type": "string" },
        "doi": { "type": "string" }
      }
    },
    "classification": {
      "type": "object",
      "required": ["primary_domain", "domains", "topics", "keywords_en", "keywords_zh"],
      "properties": {
        "primary_domain": { "type": "string" },
        "domains": { "type": "array", "items": { "type": "string" } },
        "topics": { "type": "array", "items": { "type": "string" } },
        "keywords_en": { "type": "array", "items": { "type": "string" } },
        "keywords_zh": { "type": "array", "items": { "type": "string" } }
      }
    },
    "research_card": {
      "type": "object",
      "required": [
        "one_sentence_summary_zh",
        "research_question_zh",
        "research_background_zh",
        "object_zh",
        "study_type",
        "method_zh",
        "data_or_experiment_zh",
        "model_or_algorithm_zh",
        "key_variables",
        "main_results_zh",
        "main_conclusion_zh",
        "limitations_zh",
        "usefulness_for_project_zh",
        "recommended_use_cases_zh"
      ],
      "properties": {
        "one_sentence_summary_zh": { "type": "string" },
        "research_question_zh": { "type": "string" },
        "research_background_zh": { "type": "string" },
        "object_zh": { "type": "string" },
        "study_type": { "type": "string", "description": "experiment/simulation/theory/observation/review" },
        "method_zh": { "type": "string" },
        "data_or_experiment_zh": { "type": "string" },
        "model_or_algorithm_zh": { "type": "string" },
        "key_variables": { "type": "array", "items": { "type": "string" } },
        "main_results_zh": { "type": "array", "items": { "type": "string" } },
        "main_conclusion_zh": { "type": "string" },
        "limitations_zh": { "type": "string" },
        "usefulness_for_project_zh": { "type": "string" },
        "recommended_use_cases_zh": { "type": "array", "items": { "type": "string" } }
      }
    },
    "evidence_profile": {
      "type": "object",
      "required": [
        "evidence_type",
        "data_source",
        "experiment_or_simulation_setup",
        "materials_or_region",
        "spatial_scale",
        "temporal_scale",
        "sample_size_or_cases",
        "main_equations_or_metrics"
      ],
      "properties": {
        "evidence_type": { "type": "string", "description": "wind tunnel experiment / field observation / DNS / LES / theoretical model / review" },
        "data_source": { "type": "string" },
        "experiment_or_simulation_setup": { "type": "string" },
        "materials_or_region": { "type": "string" },
        "spatial_scale": { "type": "string" },
        "temporal_scale": { "type": "string" },
        "sample_size_or_cases": { "type": "string" },
        "main_equations_or_metrics": { "type": "array", "items": { "type": "string" } }
      }
    },
    "screening": {
      "type": "object",
      "required": ["relevance_score", "reading_priority", "read_decision", "reason_zh", "best_for_sections", "not_useful_for", "need_fulltext"],
      "properties": {
        "relevance_score": { "type": ["integer", "null"], "description": "1-5 与当前项目相关性" },
        "reading_priority": { "type": ["integer", "null"], "description": "1-5 精读优先级" },
        "read_decision": { "type": "string", "enum": ["", "must_read", "maybe_read", "skip"] },
        "reason_zh": { "type": "string" },
        "best_for_sections": { "type": "array", "items": { "type": "string" } },
        "not_useful_for": { "type": "array", "items": { "type": "string" } },
        "need_fulltext": { "type": ["boolean", "null"] }
      }
    },
    "reading_priority": {
      "type": "object",
      "required": ["score", "reason_zh", "must_read_sections", "key_figures_or_tables"],
      "properties": {
        "score": { "type": ["integer", "null"] },
        "reason_zh": { "type": "string" },
        "must_read_sections": { "type": "array", "items": { "type": "string" } },
        "key_figures_or_tables": { "type": "array", "items": { "type": "string" } }
      }
    },
    "technical_tags": {
      "type": "object",
      "required": ["model_or_theory", "experiment_or_data", "parameterization", "equations_or_metrics", "materials_or_particles", "spatial_temporal_scale"],
      "properties": {
        "model_or_theory": { "type": "array", "items": { "type": "string" } },
        "experiment_or_data": { "type": "array", "items": { "type": "string" } },
        "parameterization": { "type": "array", "items": { "type": "string" } },
        "equations_or_metrics": { "type": "array", "items": { "type": "string" } },
        "materials_or_particles": { "type": "array", "items": { "type": "string" } },
        "spatial_temporal_scale": { "type": "array", "items": { "type": "string" } }
      }
    },
    "llm_search_text": {
      "type": "object",
      "required": ["compact_zh", "compact_en"],
      "properties": {
        "compact_zh": { "type": "string", "description": "200-400 字" },
        "compact_en": { "type": "string", "description": "100-200 words" }
      }
    }
  }
}
